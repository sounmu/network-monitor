# Backend API URL — the origin the BROWSER will fetch from.
#
# ⚠️  NEXT_PUBLIC_* is baked into the client bundle at BUILD time,
#     not resolved at runtime. If you change this value you must
#     re-run `npm run build` (or `docker compose up -d --build web`
#     when running under Docker Compose).
#
# Local dev (npm run dev):          http://localhost:3000
# Docker Compose in production:     set NEXT_PUBLIC_API_URL in the
#                                   repository root `.env` instead —
#                                   this file is NOT consumed by Docker.
NEXT_PUBLIC_API_URL=http://localhost:3000
