# PostgreSQL connection string
# Docker Compose:  postgres://<user>:<password>@db:5432/<db>
# Local dev:       postgres://<user>:<password>@localhost:5432/<db>
DATABASE_URL=postgres://postgres:change_me@localhost:5432/network_monitor

# JWT secret — must match the secret used in all agents
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_hex_string

# Optional: comma-separated allowed CORS origins (default: http://localhost:3001)
# ALLOWED_ORIGINS=https://your-dashboard-domain.com,http://localhost:3001

# Optional: server bind address (default: 0.0.0.0:3000)
# SERVER_HOST=0.0.0.0
# SERVER_PORT=3000

# Optional: scrape interval in seconds (default: 10)
# SCRAPE_INTERVAL_SECS=10

# Optional: max PostgreSQL connections in the pool (default: 10)
# MAX_DB_CONNECTIONS=10

# Optional: per-query statement timeout in seconds (default: 30)
# Prevents a single slow query from holding a connection indefinitely.
# DB_STATEMENT_TIMEOUT_SECS=30

# Optional: login rate limiting (per IP)
# LOGIN_RATE_LIMIT_MAX=10
# LOGIN_RATE_LIMIT_WINDOW_SECS=300

# Optional: API-wide rate limiting (per IP, all endpoints)
# API_RATE_LIMIT_MAX=200
# API_RATE_LIMIT_WINDOW_SECS=60

# Optional: number of trusted reverse proxies for X-Forwarded-For IP extraction
# Set to 1 if behind Cloudflare/nginx, 0 to use peer socket IP directly (default: 0)
# TRUSTED_PROXY_COUNT=0

# ── Notification channels ──
# Discord, Slack, and Email notifications are managed via the web dashboard UI.
# Go to Alerts > Notification Channels to add/configure channels.
# No environment variables needed — all channel configs are stored in the database.
