# PostgreSQL 기본 설정
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=super_secure_password
POSTGRES_DB=postgres_db

# Cloudflare Tunnel 환경 변수
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Next.js 컨테이너에서 백엔드 호출 퍼블릭 api url
NEXT_PUBLIC_API_URL=http://localhost:3000

# ------------------------------------------------------------------------------------------
# [환경 변수 및 네트워크 라우팅 가이드]
# 이 배포 설정은 호스트 인바운드 포트를 전면 차단하고 `cloudflared` 컨테이너를
# 통해서만 통신하는 Zero-Trust 보안 모델을 기반으로 합니다.
# 
# 1. 각 컨테이너 간의 통신 방식 (docker 내장 네트워크)
#    - 모든 컨테이너 서비스(db, server, web, tunnel)는 docker-compose의 기본 네트워크에서
#      서비스 이름(hostname)을 통해 IP 대신 직접 통신합니다. (예: `db:5432`)
#
# 2. Next.js 컨테이너에서 백엔드를 호출할 때의 내부 API URL
#    - 프론트엔드 컨테이너에서 백엔드로 데이터를 요청할 경우, `http://server:3000` 을 사용하여 통신합니다.
#    - `NEXT_PUBLIC_API_URL` 값도 `http://server:3000` 으로 기본 설정됩니다.
#
# 3. Cloudflare Dashboard Zero Trust 설정 시 라우팅 가이드라인:
#    - 호스트 서버의 어떠한 포트도 열지 않으므로 모든 요청을 Cloudflare에서 각 컨테이너로 전달(Proxy)해야 합니다.
#
#    * 프론트엔드 도메인 라우팅
#      [접속 도메인 설정 예시] -> `http://web:3000` 매핑 (사용자가 UI 접근용)
#    
#    * 에이전트 수집용 API 도메인 라우팅
#      [API 도메인 설정 예시] -> `http://server:3000` 매핑 (Agent의 메트릭 데이터가 백엔드로 전송되는 용도)
# ------------------------------------------------------------------------------------------
