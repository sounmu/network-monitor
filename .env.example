# ═════════════════════════════════════════════════════════════════════
# NetSentinel — Docker Compose / production environment
#
# This repo-root `.env` is the only env file read by `docker compose`.
# Use it for local Docker, homelab, and Cloudflare Tunnel deployments.
# `netsentinel-server/.env` is ignored by Docker Compose and exists only
# for local `cargo run` debugging.
#
# For a fresh install, run:
#
#     ./scripts/bootstrap.sh       # fills in the random secrets
#     docker compose pull server && docker compose up -d server
#                                 # pulls & starts the stack
#     ./scripts/smoke-test.sh      # verifies the install
#
# Every key here is read by docker-compose.yml; the server container
# does NOT read any other .env file in production.
# ═════════════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────────────

# JWT signing secret (≥ 32 characters). The SAME value must appear in
# every agent's .env so the server can authenticate scrapes.
# Generate with: openssl rand -hex 32
# (bootstrap.sh handles this automatically.)
JWT_SECRET=change_me_to_a_long_random_hex_string

# ── OPTIONAL — safe defaults for a localhost install ──────────────────

# Published server image tag. Leave unset for latest, or pin a release
# such as v0.4.2 for reproducible upgrades / rollbacks.
# NETSENTINEL_VERSION=latest

# Browser-facing API URL baked into a custom web bundle at BUILD time.
# The published image is built for same-origin deployments; this value
# is only consumed when you ship your own image via a
# `docker-compose.override.yml` that adds a `build:` block (see
# CONTRIBUTING.md or docs/DEPLOYMENT.md). Split-origin custom build:
#   NEXT_PUBLIC_API_URL=https://api.example.com \
#     docker compose up -d --build server
NEXT_PUBLIC_API_URL=

# Comma-separated browser origins allowed to call the API with cookies.
# For the default single-container/same-origin layout, the dashboard and
# API share one hostname and this can usually stay unset.
# Split-origin example:
#   ALLOWED_ORIGINS=https://dashboard.example.com,https://api.example.com
# Same-origin Cloudflare Tunnel example:
#   ALLOWED_ORIGINS=https://dashboard.example.com
# ALLOWED_ORIGINS=

# Refresh-cookie Secure flag. Leave true in production behind HTTPS.
# Set false only for plain-HTTP local development.
# COOKIE_SECURE=true

# SQLite file path inside the server container. docker-compose.yml sets
# this explicitly so normal deployments should not need to uncomment it.
# DATABASE_URL=sqlite:///app/data/netsentinel.db

# Server bind address inside the container. docker-compose.yml pins this
# to 0.0.0.0 so the published port can reach the service.
# SERVER_HOST=0.0.0.0

# Published host port for docker-compose.yml (`${SERVER_PORT:-3000}:3000`).
# SERVER_PORT=3000

# Scrape scheduling and database pool tuning.
# SCRAPE_INTERVAL_SECS=10
# MAX_DB_CONNECTIONS=10

# Login and API rate limits.
# LOGIN_RATE_LIMIT_MAX=30
# LOGIN_USER_RATE_LIMIT_MAX=10
# LOGIN_RATE_LIMIT_WINDOW_SECS=300
# API_RATE_LIMIT_MAX=200
# API_RATE_LIMIT_WINDOW_SECS=60

# SSE broadcast and metrics query-cache limits.
# SSE_BUFFER_SIZE=128
# METRICS_CACHE_MAX_ENTRIES=20
# METRICS_CACHE_MAX_BYTES=33554432

# SQLite runtime tuning. Use SQLITE_TEMP_STORE=FILE on very memory-constrained hosts.
# SQLITE_MMAP_SIZE=67108864
# SQLITE_CACHE_SIZE_KB=8192
# SQLITE_TEMP_STORE=MEMORY

# Trust proxy headers for client IP extraction. With Cloudflare Tunnel in
# front of the container, set to 1 so CF-Connecting-IP is honored for
# login rate limiting. Leave 0 for direct localhost/LAN access.
# TRUSTED_PROXY_COUNT=0

# Optional Prometheus scrape auth. If set, /metrics requires:
#   Authorization: Bearer <METRICS_TOKEN>
# METRICS_TOKEN=
# ALLOW_UNAUTHENTICATED_METRICS=false

# ── OPTIONAL — Cloudflare Tunnel (public deployment) ─────────────────
#
# Only needed if you run the `tunnel` service in a docker-compose
# override. Omit for a homelab-only install.
# CLOUDFLARE_TUNNEL_TOKEN=
