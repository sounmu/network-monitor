# PostgreSQL credentials
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=network_monitor

# Cloudflare Tunnel token (Zero Trust ingress)
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Backend public API URL (used by Next.js container to reach the server)
# In Docker Compose: http://server:3000
# For local dev:     http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# ------------------------------------------------------------------------------------------
# Network Routing Guide (Zero-Trust model)
#
# All services communicate through Docker's internal network using service names.
# No host ports are exposed — all inbound traffic flows through the Cloudflare Tunnel.
#
# Inter-container communication:
#   db:5432          — PostgreSQL
#   server:3000      — Rust backend
#   web:3001         — Next.js frontend
#
# Cloudflare Tunnel routing (set up in Cloudflare Zero Trust dashboard):
#   Frontend domain  → http://web:3001    (user dashboard access)
#   API domain       → http://server:3000 (agent metric ingestion)
# ------------------------------------------------------------------------------------------
