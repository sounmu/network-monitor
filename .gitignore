# Environment secrets — copy .env.example to .env and fill in your values
.env
*.env

# Per-host docker compose override.
# `docker compose` automatically merges any `docker-compose.override.yml`
# in the same directory on top of the base file, so operators can pin
# image tags, attach to an existing reverse-proxy network, or swap in
# a Cloudflare-Tunnel sidecar without ever editing tracked compose YAML.
docker-compose.override.yml
docker-compose.override.yaml

# macOS
.DS_Store

# IDE
.vscode
.idea
*.swp
*.swo

# Project-specific internal files
CLAUDE.md
.claude
AGENTS.md

# Rust build artifacts
target/
target_linux/

# Logs
logs/
*.log

# SQLite database file + WAL sidecars (bound by docker-compose.yml).
# `data/` holds netsentinel.db, netsentinel.db-wal, netsentinel.db-shm.
data/

# Node / Next.js
node_modules/
.next/

# docs/ holds internal review reports by default; whitelist the user-
# facing docs we publish alongside the code.
docs/*
!docs/AFTER_INSTALL.md
!docs/DEPLOYMENT.md

# scripts/ holds throwaway benchmarking + scratch scripts; whitelist
# the install-flow scripts the README references.
scripts/*
!scripts/bootstrap.sh
!scripts/smoke-test.sh
!scripts/doctor.sh
!scripts/install-hub.sh
!scripts/install-agent.sh
!scripts/update-hub.sh
!scripts/update-agent.sh
!scripts/remove-hub.sh
!scripts/remove-agent.sh
!scripts/publish-server-image.sh

# netsentinel-web has its own scripts/ folder used by npm start
# (export-start.mjs is the production static preview server).
!netsentinel-web/scripts/
!netsentinel-web/scripts/export-start.mjs
