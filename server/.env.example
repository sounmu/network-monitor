# ═════════════════════════════════════════════════════════════════════
# Local server debugging only (`cd netsentinel-server && cargo run`).
#
#   ⚠️  Docker Compose does NOT read this file. The repo-root `.env`
#      is the single source of truth for Docker/containerised installs.
#      Adding or changing values here will NOT affect:
#
#        docker compose up -d
#
#      because docker-compose.yml sets `env_file: .env` relative to the
#      repository root.
#
# NetSentinel stores everything in a single embedded SQLite file.
# Create `./data/` under the server crate before `cargo run`; the `.db`
# file itself (plus its `-wal` / `-shm` sidecars) is created on first
# boot.
# ═════════════════════════════════════════════════════════════════════

# SQLite file path. `sqlite://` + absolute or relative path. For
# in-memory mode while iterating on schema, use `sqlite::memory:`.
DATABASE_URL=sqlite://./data/netsentinel.db

# HS256 JWT secret. Must match every agent's .env. Generate with:
#   openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_hex_string

# ── Optional for `cargo run` dev ─────────────────────────────────────
#
# Defaults below are what the server assumes when the key is absent.
# Uncomment + tweak only what you need to change.

# ALLOWED_ORIGINS=http://localhost:3001
# COOKIE_SECURE=false            # set to false for plain-HTTP localhost dev
# SCRAPE_INTERVAL_SECS=10        # fallback when a host row has no valid value
# MAX_DB_CONNECTIONS=10
# LOGIN_RATE_LIMIT_MAX=30          # per-IP bucket (scatter-gun brute force cap)
# LOGIN_USER_RATE_LIMIT_MAX=10     # per-username bucket (targeted brute force cap)
# LOGIN_RATE_LIMIT_WINDOW_SECS=300 # shared sliding-window duration for both buckets
# API_RATE_LIMIT_MAX=200
# API_RATE_LIMIT_WINDOW_SECS=60
# SSE_BUFFER_SIZE=128             # floor is 128; env can raise but not lower
# METRICS_CACHE_MAX_ENTRIES=20
# METRICS_CACHE_MAX_BYTES=33554432 # estimated bytes per metrics query cache
# SQLITE_MMAP_SIZE=67108864       # bytes; default 64 MiB
# SQLITE_CACHE_SIZE_KB=8192       # KiB; SQLite cache_size uses negative KiB internally
# SQLITE_TEMP_STORE=MEMORY        # DEFAULT | FILE | MEMORY
# METRICS_TOKEN=                 # bearer token for /metrics Prometheus endpoint
# ALLOW_UNAUTHENTICATED_METRICS=true
# TRUSTED_PROXY_COUNT=0
# SERVER_HOST=0.0.0.0
# SERVER_PORT=3000
